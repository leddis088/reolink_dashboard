# Environment
NODE_ENV=development
PORT=4000

# Frontend origin (for CORS)
ALLOWED_ORIGIN=http://localhost:8080

# Default Reolink credentials (for devices that share the same user/pass)
# Use strong passwords. In production, consider using a secrets manager instead of plain .env.
REOLINK_DEFAULT_USER=reolink_user_placeholder
REOLINK_DEFAULT_PASSWORD=reolink_password_placeholder